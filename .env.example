# Application
DEBUG=True
LOG_LEVEL=INFO

# Database
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/farmai?charset=utf8mb4
TRACKING_DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/farmai_tracking?charset=utf8mb4

# MySQL example (uncomment and replace credentials to use MySQL):
# Use one of these SQLAlchemy URLs depending on driver:
#  - sync (PyMySQL): mysql+pymysql://<user>:<password>@127.0.0.1:3306/farmai?charset=utf8mb4
#  - async (aiomysql): mysql+aiomysql://<user>:<password>@127.0.0.1:3306/farmai?charset=utf8mb4
# Example:
# DATABASE_URL=mysql+pymysql://root:secret@127.0.0.1:3306/farmai?charset=utf8mb4

# Server
# Default binds to localhost for local-only access. Set to 0.0.0.0 to allow external access (e.g., in Docker).
HOST=127.0.0.1
PORT=8000
